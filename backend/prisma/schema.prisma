generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DEMO
  PRO
  ADMIN
}

enum JobStatus {
  PENDING
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
}

enum ProcessingMode {
  QUICK
  SMART
}

enum FileStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED
}

enum FeedbackCategory {
  BUG
  IDEA
  OTHER
}

enum FeedbackStatus {
  NEW
  REVIEWED
  RESOLVED
}

enum BillingTransactionType {
  TRIAL_USAGE
  ALLOWANCE_USAGE
  PACKAGE_USAGE
  PAYMENT_TOPUP
  MANUAL_ADJUSTMENT
  REFUND
  SUBSCRIPTION_ACTIVATION
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String?
  name                String?
  company             String?
  role                UserRole             @default(DEMO)
  isVerified          Boolean              @default(false)
  isBanned            Boolean              @default(false)
  tokenBalance        Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  sortingJobs         SortingJob[]
  feedbackSubmissions FeedbackSubmission[]
  billingTransactions BillingTransaction[]

  @@map("users")
}

model SortingJob {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         JobStatus       @default(PENDING)
  processingMode ProcessingMode  @default(SMART)
  totalFiles     Int             @default(0)
  processedFiles Int             @default(0)
  tokensReserved Int             @default(0)
  tokensUsed     Int             @default(0)
  outputZipPath  String?
  registryPath   String?
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  files          ProcessedFile[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("sorting_jobs")
}

model ProcessedFile {
  id            String     @id @default(cuid())
  jobId         String
  job           SortingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  originalName  String
  originalPath  String
  processedPath String?
  processedName String?
  ocrText       String?    @db.Text
  docType       String?
  docDate       String?
  docNumber     String?
  docParties    String[]   @default([])
  docSummary    String?
  outputPdfPath String?
  pageCount     Int        @default(1)
  sizeBytes     Int        @default(0)
  orderIndex    Int        @default(0)
  groupIndex    Int?
  status        FileStatus @default(PENDING)
  errorMessage  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([orderIndex])
  @@map("processed_files")
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@map("verification_codes")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model FeedbackSubmission {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionSlug       String
  conversationId    String
  conversationTitle String
  messageId         String?
  messagePreview    String?          @db.Text
  category          FeedbackCategory
  content           String           @db.Text
  status            FeedbackStatus   @default(NEW)
  adminNote         String?          @db.Text
  source            String           @default("form")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("feedback_submissions")
}

model BillingTransaction {
  id           String                 @id @default(cuid())
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         BillingTransactionType
  tokenDelta   Int                    @default(0)
  usageTokens  Int                    @default(0)
  amount       Int?
  currency     String?
  description  String?
  balanceAfter Int                    @default(0)
  createdAt    DateTime               @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("billing_transactions")
}
