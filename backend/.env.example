DATABASE_URL=postgresql://lexdoc:lexdoc_secret@localhost:5432/lexdoc
JWT_SECRET=your-secret-key
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
PORT=3001
OTP_DEV_MODE=true
REDIS_HOST=localhost
REDIS_PORT=6379
OCR_ENABLED=true
OCR_LANGUAGES=rus+eng
OCR_MAX_PDF_PAGES=3

GEMINI_API_KEY=
RESEND_API_KEY=

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM="Lex-Doc Sorter <noreply@lex-sorter.ru>"
EMAIL_SUBJECT="Код доступа к Lex-Doc Sorter"

STORAGE_TYPE=local
STORAGE_PATH=./uploads
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=lex-doc-files
S3_ACCESS_KEY=
S3_SECRET_KEY=
