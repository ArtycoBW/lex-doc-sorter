# Backend
DATABASE_URL=postgresql://lexdoc:lexdoc_secret@localhost:5432/lexdoc
JWT_SECRET=your-secret-key
NODE_ENV=development
GEMINI_API_KEY=
RESEND_API_KEY=
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM="Lex-Doc Sorter <noreply@lex-sorter.ru>"
EMAIL_SUBJECT="Код доступа к Lex-Doc Sorter"
STORAGE_TYPE=local
STORAGE_PATH=./uploads
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=lex-doc-files
S3_ACCESS_KEY=
S3_SECRET_KEY=
PORT=3001
OTP_DEV_MODE=true
REDIS_HOST=localhost
REDIS_PORT=6379
OCR_ENABLED=true
OCR_LANGUAGES=rus+eng
OCR_MAX_PDF_PAGES=3

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Docker/Postgres
POSTGRES_DB=lexdoc
POSTGRES_USER=lexdoc
POSTGRES_PASSWORD=lexdoc_secret

# Docker build network
# Fill these only if Docker Desktop cannot reach npm registry directly.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis,backend
NPM_REGISTRY=https://registry.npmjs.org/
